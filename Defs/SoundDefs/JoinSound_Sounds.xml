<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ============================================================
       PAWN JOINED SOUND
       Plays when a pawn joins the colony from outside the map.

       Audio file: Sounds/JoinSound/pawn_joined.ogg  (already included)
       To swap the sound, replace pawn_joined.ogg with your own OGG Vorbis file
       and restart RimWorld.
       ============================================================ -->

  <SoundDef>
    <defName>JoinSound_PawnJoined</defName>
    <label>Pawn joined colony</label>

    <!-- MapOnly: RimWorld requires this for on-camera sounds (context=Any causes a
         config error in 1.6 and silently breaks playback). A map will always be
         loaded when a colonist joins or a trader arrives on the colony map.
         If you are on the world map when a trader is announced, the sound won't
         play — that is acceptable and expected behaviour. -->
    <context>MapOnly</context>

    <subSounds>
      <li>
        <!-- Volume range gives a slight natural variation each time -->
        <volumeRange>
          <min>0.9</min>
          <max>1.0</max>
        </volumeRange>

        <!-- Pitch range: 1.0 = no shift. Widen slightly for variety. -->
        <pitchRange>
          <min>0.97</min>
          <max>1.03</max>
        </pitchRange>

        <grains>
          <li Class="AudioGrain_Clip">
            <!-- Path is relative to this mod's Sounds/ folder. No extension. -->
            <clipPath>JoinSound/pawn_joined</clipPath>
          </li>
        </grains>
      </li>
    </subSounds>
  </SoundDef>


  <!-- ============================================================
       TRADER ARRIVED SOUND  (optional feature, off by default)
       Plays when any trader arrives — either orbital (comms console)
       or a walk-in caravan trader.

       HOW TO USE A DIFFERENT CLIP FOR TRADERS:
         Place "trader_arrived.ogg" in Sounds/JoinSound/ and change
         the clipPath below to "JoinSound/trader_arrived".
         By default it reuses the same clip as the join sound.
       ============================================================ -->

  <SoundDef>
    <defName>JoinSound_TraderArrived</defName>
    <label>Trader arrived at colony</label>

    <!-- MapOnly: required to avoid the 1.6 config validation error that breaks
         sounds marked context=Any without an explicit on-camera flag. -->
    <context>MapOnly</context>

    <subSounds>
      <li>
        <volumeRange>
          <min>0.85</min>
          <max>0.95</max>
        </volumeRange>

        <pitchRange>
          <min>0.95</min>
          <max>1.05</max>
        </pitchRange>

        <grains>
          <li Class="AudioGrain_Clip">
            <!-- Change to "JoinSound/trader_arrived" if you want a separate clip -->
            <clipPath>JoinSound/pawn_joined</clipPath>
          </li>
        </grains>
      </li>
    </subSounds>
  </SoundDef>

</Defs>
